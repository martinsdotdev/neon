{
  "extends": "../../tsconfig.base.json",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "eslint.config.js",
    "prettier.config.js",
    "vite.config.js"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@neon/domain/*": ["../../packages/domain/src/*"],
      "@neon/client/*": ["../../packages/client/src/*"],
      "@neon/tokens/*": ["../../packages/tokens/src/*"]
    }
  }
}
