<configuration>
  <statusListener class="ch.qos.logback.core.status.NopStatusListener" />

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%-40logger{40}) [%X{traceId:-}] [%X{entityType:-}:%X{entityId:-}] | %msg%n</pattern>
    </encoder>
  </appender>

  <logger name="neon" level="DEBUG" />
  <logger name="org.apache.pekko" level="WARN" />
  <logger name="io.r2dbc" level="WARN" />

  <root level="INFO">
    <appender-ref ref="CONSOLE" />
  </root>
</configuration>
